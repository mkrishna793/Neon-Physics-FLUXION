   "source": [
    "# FLUXION v4: HAPR Engine (Kaggle / Colab Quickstart)\n",
    "\n",
    "This notebook installs Rust and compiles the FLUXION v4 core engine on a cloud GPU instance. Because FLUXION uses WebGPU (`wgpu`), it will automatically target the Vulkan drivers on the Linux machine to execute the force and congestion shaders."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "!curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.js | sh -s -- -y\n",
    "import os\n",
    "os.environ['PATH'] += \":/root/.cargo/bin\"\n",
    "!rustc --version"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Install python dependencies\n",
    "!pip install maturin z3-solver pyyaml numpy matplotlib pytest"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Compile the Rust engine (Release mode for maximum performance)\n",
    "!cargo build --release"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Run the test suite\n",
    "!cargo test"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Run placement on the test fixture\n",
    "!cargo run --release -- --input tests/fixtures/small.blif --output kaggle_placed.def\n",
    "!cat kaggle_placed.def"
   ]
  }
 ],
